# Auto-generated Deployment by Bob
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{APP_NAME}}
  namespace: {{OPENSHIFT_NAMESPACE}}
  labels:
    app: {{APP_NAME}}
    generated-by: bob
spec:
  replicas: {{REPLICAS}}
  selector:
    matchLabels:
      app: {{APP_NAME}}
  template:
    metadata:
      labels:
        app: {{APP_NAME}}
        version: v1
    spec:
      containers:
      - name: {{APP_NAME}}
