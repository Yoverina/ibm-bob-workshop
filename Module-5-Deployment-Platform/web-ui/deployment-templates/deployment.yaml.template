          requests:
            memory: "128Mi"
            cpu: "100m"
          limits:
            memory: "512Mi"
            cpu: "500m"
        {{#HEALTH_CHECK_PATH}}
        livenessProbe:
          httpGet:
            path: {{HEALTH_CHECK_PATH}}
            port: {{APP_PORT}}
          initialDelaySeconds: 30
          periodSeconds: 10
          timeoutSeconds: 3
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: {{HEALTH_CHECK_PATH}}
            port: {{APP_PORT}}
          initialDelaySeconds: 10
          periodSeconds: 5
          timeoutSeconds: 3
          failureThreshold: 3
        {{/HEALTH_CHECK_PATH}}
      imagePullSecrets:
      - name: dockerhub-secret
      restartPolicy: Always