# OpenShift Cluster Credentials Template
# Copy this file to credentials.yaml and fill in your actual values
# DO NOT commit credentials.yaml to version control!

cluster:
  # OpenShift API URL (provided by instructor)
  api_url: "https://api.your-cluster.example.com:6443"
  
  # OpenShift Console URL
  console_url: "https://console-openshift-console.apps.your-cluster.example.com"
  
  # Your username (provided by instructor)
  username: "your-username"
  
  # Your password (provided by instructor)
  password: "your-password"

# Optional: Bastion/Jump server access (if required)
bastion:
  host: "bastion.your-cluster.example.com"
  port: 22
  username: "your-bastion-username"
  password: "your-bastion-password"

# Notes:
# - Keep this file secure and never share it
# - Use strong passwords
# - Change default passwords immediately
# - Enable MFA if available